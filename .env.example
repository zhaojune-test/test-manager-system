# 测试管理系统 - 环境配置示例
# 本地开发：复制此文件为 .env 并填入实际值
# 云端部署：在 Railway 平台的环境变量中配置

# ==================== LLM API 配置 ====================
# MiniMax API (用于 AI 测试用例生成、报告生成)
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# 智谱 GLM API (备选)
GLM_API_KEY=

# 默认 LLM 提供商: minimax 或 glm
DEFAULT_LLM_PROVIDER=minimax

# ==================== 服务配置 ====================
FLASK_PORT=5000
FLASK_DEBUG=false

# ==================== 云端部署 (Railway) ====================
# Railway 会自动注入 DATABASE_URL 等变量
# 如果使用 Neon PostgreSQL，DATABASE_URL 格式:
# postgresql://user:password@host:5432/dbname
